# --- App URL (used in x402 `resource` field; set in production) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Solana network: solana-devnet (default) | solana (mainnet) ---
NEXT_PUBLIC_SOLANA_NETWORK=solana-devnet

# Required for mainnet in the browser: public `api.mainnet-beta.solana.com` often returns 403.
# Also used by the x402 payment client (`createX402Client`) — must match wallet `ConnectionProvider`.
# NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Client x402 amount must match server X402_UNLOCK_PRICE_ATOMIC when you override price
# NEXT_PUBLIC_X402_UNLOCK_PRICE_ATOMIC=100000

# Optional USDC mint override (defaults to known devnet/mainnet mints)
# NEXT_PUBLIC_USDC_MINT=

# --- x402 USDC payments: set treasury to enable HTTP 402 + facilitator flow ---
# Leave unset for local demo unlocks without on-chain payment.
# IMPORTANT: this wallet must already have a USDC associated token account (ATA) for the
# mint you use (mainnet USDC: EPjF…). PayAI verification requires tx shape: compute limit,
# compute price, then TransferChecked only — auto-creating the receiver ATA in the same tx is not supported.
TREASURY_WALLET_ADDRESS=

# PayAI facilitator (default matches x402-solana docs)
# X402_FACILITATOR_URL=https://facilitator.payai.network

# Unlock price in USDC atomic units (6 decimals). Default 100000 = 0.1 USDC
# X402_UNLOCK_PRICE_ATOMIC=100000

# X402_UNLOCK_DESCRIPTION=RentChain property detail unlock

# Server-only RPC (optional; falls back to public cluster if unset)
# SOLANA_RPC_URL=

# Optional PayAI facilitator JWT (higher limits than anonymous)
# PAYAI_API_KEY_ID=
# PAYAI_API_KEY_SECRET=
