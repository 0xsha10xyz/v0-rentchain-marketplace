# Backend HTTP
PORT=4000
# Comma-separated list. Example: http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000

# Public backend origin (IMPORTANT for x402 resource URL)
# Local: http://localhost:4000
APP_URL=http://localhost:4000

# Solana network
SOLANA_NETWORK=solana-devnet

# x402 enablement (set treasury to enable real payments)
# Treasury must already have a USDC ATA for your mint (PayAI verify expects standard 3-instruction payment tx).
TREASURY_WALLET_ADDRESS=

# Optional (recommended if facilitator requires/you want higher limits)
PAYAI_API_KEY_ID=
PAYAI_API_KEY_SECRET=

# Optional overrides
# SOLANA_RPC_URL=
# USDC_MINT=
# X402_FACILITATOR_URL=https://facilitator.payai.network
# X402_UNLOCK_PRICE_ATOMIC=100000
# X402_UNLOCK_DESCRIPTION=RentChain property detail unlock

